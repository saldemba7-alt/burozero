# Backend — copia para .env e preenche

MONGODB_URL=mongodb://localhost:27017
DB_NAME=burozero

# JWT (muda em produção — usa: openssl rand -hex 32)
JWT_SECRET=burozero-secret-muda-em-producao-agora

# Gmail SMTP — usa um App Password, não a tua password normal
# Tutorial: myaccount.google.com → Segurança → Palavras-passe de aplicações
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=o.teu@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# (Opcional) Em dev deixa SMTP_USER vazio — o código OTP aparece na consola
