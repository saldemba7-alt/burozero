# Frontend Expo — copia para .env

# URL do teu backend (em dev usa o IP local da máquina, não localhost)
# Ex: http://192.168.1.100:8000/api
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Project ID do Expo (encontras em expo.dev após criar o projecto)
# Necessário para notificações push em produção
EXPO_PUBLIC_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
